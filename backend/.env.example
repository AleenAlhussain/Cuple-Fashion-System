APP_NAME=CupleShop
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
ASSET_URL=${APP_URL}

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=4

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=cuple_shop
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,localhost:3001,127.0.0.1,127.0.0.1:3000,127.0.0.1:8000

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

# Use 'file' if Redis is not installed (XAMPP users)
# Use 'redis' if Redis is installed (Laragon users)
CACHE_STORE=file
CACHE_PREFIX=cuple_

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
STRIPE_SECRET=
STRIPE_PUBLISHABLE_KEY=
STRIPE_CURRENCY=aed

GEO_REVERSE_URL=https://nominatim.openstreetmap.org/reverse
GEO_REVERSE_TIMEOUT=10
GEO_USER_AGENT="CupleShop/1.0 (support@cuple.shop)"
GEO_REFERER=${APP_URL}
GEO_EMAIL=support@cuple.shop

#Aramex (get credentials from team)
ARAMEX_ENV=dev
ARAMEX_USERNAME=
ARAMEX_EMAIL=
ARAMEX_PASSWORD=
ARAMEX_ACCOUNT_NUMBER=
ARAMEX_ACCOUNT_PIN=
ARAMEX_ACCOUNT_ENTITY=DXB
ARAMEX_ACCOUNT_COUNTRY_CODE=AE
ARAMEX_SHIP_WSDL=https://ws.aramex.net/shippingapi.v2/shipping/service_1_0.svc?wsdl
ARAMEX_TRACKING_URL_LIVE=https://ws.aramex.net/shippingapi/tracking/service_1_0.svc
ARAMEX_SHIPPING_URL=https://ws.aramex.net/shippingapi.v2/shipping/service_1_0.svc
ARAMEX_TRACKING_URL=https://ws.aramex.net/shippingapi/tracking/service_1_0.svc

MEDIA_LOCALIZE_EXTERNAL=true
MEDIA_ALLOWED_EXTERNAL_HOSTS=cuple.ae,*.cuple.ae
MEDIA_MAX_FILE_SIZE_MB=15
MEDIA_DOWNLOAD_TIMEOUT_SECONDS=30
MEDIA_DOWNLOAD_USER_AGENT="CupleBot/1.0"

WHATSAPP_ENABLED=false
WHATSAPP_ZAPIER_WEBHOOK_URL= # legacy shared fallback
WHATSAPP_ZAPIER_LOGIN_WEBHOOK_URL=
WHATSAPP_ZAPIER_ORDER_WEBHOOK_URL=
WHATSAPP_ZAPIER_TEMPLATE_NAME=code_login_v1
WHATSAPP_ZAPIER_TEMPLATE_LANGUAGE=en
WHATSAPP_TIMEOUT=15
